<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#0a0a1a"
    android:orientation="vertical"
    android:padding="6dp"
    android:minHeight="280dp">

    <!-- Editable text preview area -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:background="@drawable/preview_bg"
        android:padding="2dp">
        <EditText
            android:id="@+id/et_preview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="10dp"
            android:textColor="#e2e8f0"
            android:textSize="15sp"
            android:lineSpacingMultiplier="1.3"
            android:hint="Speak or type here…"
            android:textColorHint="#4a5568"
            android:background="@android:color/transparent"
            android:gravity="top|start"
            android:inputType="textMultiLine"
            android:importantForAutofill="no" />
    </ScrollView>

    <!-- Status line -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tap mic to speak"
        android:textColor="#64748b"
        android:textSize="11sp"
        android:gravity="center"
        android:paddingVertical="3dp" />

    <!-- Row 1: Mic button centered with Enter and Backspace on sides -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <!-- Enter / New Line -->
        <Button
            android:id="@+id/btn_enter"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="⏎"
            android:textSize="20sp"
            android:background="@drawable/btn_dark_rounded"
            android:textColor="#94a3b8"
            android:layout_marginEnd="6dp" />

        <!-- Mic Button -->
        <ImageButton
            android:id="@+id/btn_mic"
            android:layout_width="60dp"
            android:layout_height="56dp"
            android:background="@drawable/btn_mic_bg"
            android:src="@android:drawable/ic_btn_speak_now"
            android:contentDescription="Microphone"
            android:scaleType="centerInside"
            android:padding="12dp" />

        <!-- Backspace / Delete -->
        <Button
            android:id="@+id/btn_backspace"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="⌫"
            android:textSize="20sp"
            android:background="@drawable/btn_dark_rounded"
            android:textColor="#94a3b8"
            android:layout_marginStart="6dp" />
    </LinearLayout>

    <!-- Row 2: Clean + Insert -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:orientation="horizontal"
        android:layout_marginBottom="3dp">

        <Button
            android:id="@+id/btn_clean"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="✨ Clean"
            android:textSize="12sp"
            android:background="@drawable/btn_purple_rounded"
            android:textColor="#a5b4fc"
            android:layout_marginEnd="3dp" />

        <Button
            android:id="@+id/btn_insert"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="✅ Insert"
            android:textSize="12sp"
            android:background="@drawable/btn_green_rounded"
            android:textColor="#86efac" />
    </LinearLayout>

    <!-- Row 3: Switch + Delete Word + Undo + Clear -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_switch"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="⌨️"
            android:textSize="14sp"
            android:background="@drawable/btn_dark_rounded"
            android:textColor="#94a3b8"
            android:layout_marginEnd="3dp" />

        <Button
            android:id="@+id/btn_delete_word"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.5"
            android:text="⌫ Word"
            android:textSize="11sp"
            android:background="@drawable/btn_dark_rounded"
            android:textColor="#94a3b8"
            android:layout_marginEnd="3dp" />

        <Button
            android:id="@+id/btn_undo"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="↩ Undo"
            android:textSize="11sp"
            android:background="@drawable/btn_dark_rounded"
            android:textColor="#94a3b8"
            android:layout_marginEnd="3dp" />

        <Button
            android:id="@+id/btn_clear"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Clear"
            android:textSize="11sp"
            android:background="@drawable/btn_red_rounded"
            android:textColor="#fca5a5" />
    </LinearLayout>

</LinearLayout>
